{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Права окна-поповера: invoke команд, открытие localhost-ссылок, автообновление.",
  "windows": ["popover"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "http://localhost:*" }]
    },
    "clipboard-manager:allow-write-text",
    "updater:default",
    "process:allow-restart"
  ]
}
