{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "portist",
  "version": "0.3.1",
  "identifier": "com.viktor.portist",
  "build": {
    "beforeDevCommand": "pnpm start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist/portist/browser"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/blasdfaa/portist/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGQ0NBNThBODVDQTY1MzYKUldRMlpjcUZpcVhNNzJDa3g3amlRMDRhbkQyTkFGL245QmNkbGFTdVd4WEY2M0o3aktaSHUwOW0K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
